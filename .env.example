# Copia este archivo a .env y rellena tus valores. NO subas el .env real.
# El token lo obtienes de @BotFather en Telegram.
TELEGRAM_BOT_TOKEN=tu_token_aqui
# xpub PÚBLICA para las donaciones (de tu wallet, ej. Sparrow). Empieza con xpub/zpub.
DONATION_XPUB=tu_xpub_publica_aqui
# Tu Telegram ID (o varios separados por coma) para usar /broadcast y /stats.
ADMIN_IDS=tu_telegram_id_aqui
# Conexión a Postgres (Supabase/Neon/Railway). Activa guardado de usuarios + /broadcast.
DATABASE_URL=postgresql://usuario:password@host:5432/dbname
